        <spring-boot.version>3.1.8</spring-boot.version>
        <spring-boot-admin-starter-client.version>3.0.0</spring-boot-admin-starter-client.version>
        <spring-rabbit-test.version>2.4.6</spring-rabbit-test.version>
        <spring-cloud.version>2022.0.1</spring-cloud.version>
        <spring-cloud-starter-openfeign.version>3.1.1</spring-cloud-starter-openfeign.version>
