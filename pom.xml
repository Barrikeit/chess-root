        <logstash-gelf.version>1.15.0</logstash-gelf.version>
        <pdfbox.version>2.0.26</pdfbox.version>
        <!-- VERSIONES BBDD -->
        <hibernate.version>6.1.6.Final</hibernate.version>
        <querydsl.version>5.0.0</querydsl.version>
        <zipkin-reporter-brave.version>2.16.3</zipkin-reporter-brave.version>
        <!-- VERSIONES TESTS -->
        <assertj.version>3.24.2</assertj.version>
        <junit-jupiter.version>5.9.2</junit-jupiter.version>
        <mockito-junit-jupiter.version>4.8.1</mockito-junit-jupiter.version>
        <!-- VERSIONES PLUGINS -->
        <maven.version>3.2.5</maven.version>
        <maven-compiler-plugin.version>3.10.1</maven-compiler-plugin.version>
        <maven-enforcer-plugin.version>3.1.0</maven-enforcer-plugin.version>
        <maven-failsafe-plugin.version>2.22.0</maven-failsafe-plugin.version>
        <maven-resources-plugin.version>3.2.0</maven-resources-plugin.version>
        <maven-surefire-plugin.version>2.22.2</maven-surefire-plugin.version>
        <maven-war-plugin.version>3.3.2</maven-war-plugin.version>
        <maven-jar-plugin.version>3.0.0</maven-jar-plugin.version>
        <sonar-maven-plugin.version>3.9.1.2184</sonar-maven-plugin.version>
        <apt-maven-plugin.version>1.1.3</apt-maven-plugin.version>
        <modernizer-maven-plugin.version>2.3.0</modernizer-maven-plugin.version>
        <jacoco-maven-plugin.version>0.8.10</jacoco-maven-plugin.version>
        <git-commit-id-maven-plugin.version>5.0.0</git-commit-id-maven-plugin.version>
        <pitest-junit5-plugin.version>0.15</pitest-junit5-plugin.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- CHESS ROOT DEPENDENCIES -->
            <dependency>
